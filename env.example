# WhatsApp Bridge
WHATSAPP_BRIDGE_URL=http://localhost:8080
WHATSAPP_BRIDGE_WS_URL=ws://localhost:8080/ws
BRIDGE_PORT=8080
BRIDGE_DB_PATH=data/whatsapp.db

# Auth — comma-separated phone numbers
ALLOWED_PHONES=5511999999999

# Claude
# ANTHROPIC_API_KEY=sk-ant-...   # Optional if CLI already logged in
APPROVED_DIRECTORY=/home/user/projects
CLAUDE_MAX_TURNS=25
CLAUDE_TIMEOUT_SECONDS=300
CLAUDE_MAX_COST_PER_REQUEST=5.0

# Features
AGENTIC_MODE=true
VERBOSE_LEVEL=1
ENABLE_MCP=false

# Storage
DATABASE_URL=sqlite:///data/whatsapp_bot.db

# Development
DEBUG=false
DEVELOPMENT_MODE=false
